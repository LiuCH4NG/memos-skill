# Memos Note Skill - Environment Configuration
# Copy this file to .env and fill in your actual values

# Your Memos instance base URL (no trailing slash)
MEMOS_API_URL=https://your-memos-instance.com

# Your Memos API access token
# Get it from: Memos Settings → API → Create Access Token
MEMOS_API_TOKEN=your_api_token_here
